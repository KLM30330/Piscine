    //   0x63 = 99  (Atlas pH)
    //   0x62 = 98  (Atlas ORP)
    //   0x66 = 102 (Atlas RTD)
    //   0x67 = 103 (Atlas pompe pH)
    //   0x20 = 32  (PCF8574 relais)
    //   0x27 = 39  (LCD I2C)
    "I2cBus":        1,
    "AtlasPhAddr":   99,
    "AtlasOrpAddr":  98,
    "AtlasRtdAddr":  102,
    "AtlasPmpAddr":  103,
    "Pcf8574Addr":   32,
    "LcdI2cAddr":    39,

    // ── 1-Wire DS18B20 ────────────────────────────────────────────────────────
    "OnewirePumpSensorId": "28-0103804a321b",
    "PumpTempAlertC":    60.0,
    "PumpTempCriticalC": 70.0,

    // ── GPIO boutons (numérotation BCM) ───────────────────────────────────────
    "BtnLcdDisplay":    5,
    "BtnPrimePump":     6,
    "BtnPauseFilter":   13,
    "BtnResumeFilter":  19,

    // ── Modbus WK600-D ────────────────────────────────────────────────────────
