<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <InvariantGlobalization>true</InvariantGlobalization>
    <PublishAot>true</PublishAot>
    <!-- System.Device.Gpio 3.x targets net6.0 without AOT annotations → IL2104.
         Suppress ILC errors only; C# compiler TreatWarningsAsErrors still active. -->
    <IlcTreatWarningsAsErrors>false</IlcTreatWarningsAsErrors>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.*" />
    <PackageReference Include="MQTTnet" Version="5.*" />
    <PackageReference Include="System.Device.Gpio" Version="3.*" />
    <PackageReference Include="System.IO.Ports" Version="9.*" />
  </ItemGroup>
</Project>
