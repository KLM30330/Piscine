<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>

    <!-- OK pour Raspberry -->
    <InvariantGlobalization>true</InvariantGlobalization>

    <!-- ❌ SUPPRIMÉ : AOT incompatible avec GPIO / Serial -->
    <!-- <PublishAot>true</PublishAot> -->

    <!-- optionnel mais utile -->
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.*" />
    <PackageReference Include="MQTTnet" Version="5.*" />

    <!-- GPIO Raspberry -->
    <PackageReference Include="System.Device.Gpio" Version="4.*" />

    <!-- Série (RS485 / UART) -->
    <PackageReference Include="System.IO.Ports" Version="10.*" />
  </ItemGroup>

</Project>
